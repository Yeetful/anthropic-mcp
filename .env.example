# Your Anthropic API key — used for all inference on behalf of paying clients.
ANTHROPIC_API_KEY=sk-ant-...

# The wallet that receives USDC payments on Base. REQUIRED in production —
# leaving this unset will fail loudly so you don't accidentally route revenue
# to a fallback address.
PAYMENT_ADDRESS=0xYourBaseWalletHere

# Which EVM network to settle on. "base" for mainnet, "base-sepolia" for testnet.
# Bazaar / agent.market only indexes mainnet ("base") services.
X402_NETWORK=base

# Price charged per inference call, in USD. The facilitator converts to USDC.
X402_PRICE_USD=0.01

# Default model. The MCP schema does NOT let clients override this — the
# server picks. Haiku 4.5 keeps a $0.01 charge profitable; Sonnet/Opus need
# X402_PRICE_USD bumped accordingly.
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5

# --- Coinbase CDP facilitator credentials (REQUIRED for agent.market listing) ---
# Bazaar's crawler only indexes services settled through the CDP facilitator.
# Create a key at https://portal.cdp.coinbase.com/access/api
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
