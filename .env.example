# Your Anthropic API key — used for all inference on behalf of paying clients.
ANTHROPIC_API_KEY=sk-ant-...

# The wallet that receives USDC payments on Base.
PAYMENT_ADDRESS=0x66268791B55e1F5fA585D990326519F101407257

# Which EVM network to settle on. "base" for mainnet, "base-sepolia" for testnet.
X402_NETWORK=base

# Facilitator URL. Leave unset to use Coinbase CDP's hosted facilitator (mainnet),
# or set to https://x402.org/facilitator for base-sepolia testing.
# X402_FACILITATOR_URL=https://x402.org/facilitator

# Price charged per inference call, in USD. The facilitator converts to USDC.
X402_PRICE_USD=0.01

# Default model if the client doesn't specify one.
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
